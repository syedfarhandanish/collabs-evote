generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL")
}

// 1. School Admin Account
model School {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  password_hash String
  positions     String[]     @default([]) // <-- NEW: Array to store custom election positions
  students      Student[]
  contestants   Contestant[]
  votes         Vote[]
  createdAt     DateTime     @default(now())
}

// 2. Student Data
model Student {
  id                String   @id @default(cuid())
  schoolId          String
  student_id_string String   // ID provided by the school (e.g., S-101)
  name              String   
  password_hash     String   // Randomly generated password
  grade             String
  section           String
  has_voted         Boolean  @default(false)
  school            School   @relation(fields: [schoolId], references: [id])
  votes             Vote[]
  createdAt         DateTime @default(now())

  // Two students in the same school cannot have the same ID
  @@unique([schoolId, student_id_string]) 
}

// Visibility Options
enum Visibility {
  ALL_STUDENTS
  SPECIFIC_GRADE
  SPECIFIC_SECTION // <-- NEW: Only show to matching grade AND section
}

// 3. Election Candidates (Contestants)
model Contestant {
  id         String     @id @default(cuid())
  schoolId   String
  name       String
  grade      String
  section    String
  position   String     // e.g., President, Class Representative
  photo_url  String?
  visibility Visibility @default(ALL_STUDENTS)
  school     School     @relation(fields: [schoolId], references: [id])
  votes      Vote[]
  createdAt  DateTime   @default(now())
}

// 4. Voting Record (To prevent double voting)
model Vote {
  id           String     @id @default(cuid())
  schoolId     String
  studentId    String
  contestantId String
  position     String
  school       School     @relation(fields: [schoolId], references: [id])
  student      Student    @relation(fields: [studentId], references: [id])
  contestant   Contestant @relation(fields: [contestantId], references: [id])
  createdAt    DateTime   @default(now())

  // A student can only vote once per position
  @@unique([studentId, position]) 
}